int leftMostIndex(int arraySize, int integerArray[], int desiredNumber) {
    The function performs a binary search to find the leftmost occurrence of a given number in a sorted array.

    int l = 0;
    The left boundary of the search space is initialized to the first index of the array.

    int r = arraySize - 1;
    The right boundary of the search space is initialized to the last index of the array.

    int index = -1;
    This variable stores the result index. It is set to -1 initially, meaning "not found".

    while (l <= r) {
        The loop continues as long as the search space is valid.

        int mid = (l + r) / 2;
        The middle index of the current search range is calculated.

        if (integerArray[mid] == desiredNumber) {
            If the middle element matches the desired number,

            index = mid;
            The current index is stored as a possible answer.

            r = mid - 1;
            The search continues on the left side to find the first occurrence.
        }

        else if (integerArray[mid] < desiredNumber) {
            If the middle element is smaller than the desired number,

            l = mid + 1;
            The search moves to the right half.
        }

        else {
            If the middle element is greater than the desired number,

            r = mid - 1;
            The search moves to the left half.
        }
    }

    return index;
    The function returns the leftmost index if found, otherwise returns -1.
}

int main() {
    int arraySize;
    cin >> arraySize;
    The size of the array is taken as input.

    int integerArray[arraySize];
    An array of the given size is declared.

    for (int i = 0; i < arraySize; i++) {
        cin >> integerArray[i];
        Each element of the array is taken as input.
    }

    int desiredNumber;
    cin >> desiredNumber;
    The target number to be searched is taken as input.

    sort(integerArray, integerArray + arraySize);
    The array is sorted in ascending order before applying binary search.

    int index = leftMostIndex(arraySize, integerArray, desiredNumber);
    The function is called to find the leftmost index of the target number.

    if (index == -1) {
        cout << "Element Isn't Found\n";
        If the function returns -1, the element does not exist in the array.
    }

    else {
        cout << "Leftmost Index: " << index << "\n";
        If found, the leftmost index is printed.
    }

    return 0;
}
